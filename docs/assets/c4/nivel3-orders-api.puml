@startuml nivel3-orders-api
!include <C4/C4_Component>

LAYOUT_TOP_DOWN()
LAYOUT_WITH_LEGEND()
title Nivel 3 — Componentes: orders-api

Container_Ext(gateway, "API Gateway", "Kong")
Container_Ext(itemsApi, "items-api")
Container_Ext(usersApi, "users-api")
Container_Ext(metricsApi, "metrics-api")
Container_Ext(obs, "render-observability", "Pushgateway")
System_Ext(stripe, "Stripe")
System_Ext(expo, "Expo Push")
ContainerDb(db, "orders DB", "PostgreSQL")

Container_Boundary(c, "orders-api") {
    Component(router, "Router", "Go/Gin", "Ruteo con middleware\nde autenticación")
    Component(cart_handler, "Cart Handler", "Go", "Agrega, lista\ny elimina items")
    Component(checkout_handler, "Checkout Handler", "Go", "Inicia el flujo\nde compra")
    Component(order_handler, "Order Handler", "Go", "Consulta y actualiza\nestado de órdenes")
    Component(cart_svc, "Cart Service", "Go", "Lógica del carrito\ny validación de items")
    Component(order_svc, "Order Service", "Go", "Orquesta checkout:\nreserva, pago y notificaciones")
    Component(payment_gw, "Payment Gateway", "Go", "Abstracción sobre\nStripe (o mock en dev)")
    Component(cart_repo, "Cart Repository", "Go/pgx", "Persistencia del carrito")
    Component(order_repo, "Order Repository", "Go/pgx", "Persistencia de órdenes")
    Component(items_client, "Items Client", "Go/HTTP", "Valida items\ny reserva stock")
    Component(users_client, "Users Client", "Go/HTTP", "Obtiene push tokens")
    Component(metrics_client, "Metrics Client", "Go/HTTP", "Publica eventos\nde cambio de estado")
    Component(push_client, "Push Client", "Go/HTTP", "Notificaciones\nvia Expo")
    Component(obs_client, "Pushgateway Client", "Go/HTTP", "Push de métricas\ncada 15 segundos")
}

Lay_R(gateway, itemsApi)
Lay_R(itemsApi, usersApi)
Lay_R(usersApi, metricsApi)
Lay_D(gateway, router)
Lay_R(cart_handler, checkout_handler)
Lay_R(checkout_handler, order_handler)
Lay_D(cart_handler, cart_svc)
Lay_D(checkout_handler, order_svc)
Lay_D(cart_svc, cart_repo)
Lay_D(order_svc, order_repo)
Lay_D(order_svc, payment_gw)
Lay_R(order_svc, items_client)
Lay_R(order_svc, users_client)
Lay_R(order_svc, metrics_client)
Lay_R(order_svc, push_client)
Lay_D(cart_repo, db)
Lay_D(order_repo, db)
Lay_D(payment_gw, stripe)
Lay_R(push_client, expo)
Lay_D(obs_client, obs)

Rel(gateway, router, "HTTPS")
Rel(router, cart_handler, "/carts/*")
Rel(router, checkout_handler, "/orders/checkout")
Rel(router, order_handler, "/orders/*")
Rel(cart_handler, cart_svc, "")
Rel(checkout_handler, order_svc, "")
Rel(order_handler, order_repo, "")
Rel(cart_svc, cart_repo, "")
Rel(cart_svc, items_client, "Valida items")
Rel(order_svc, items_client, "Reserva stock")
Rel(order_svc, payment_gw, "")
Rel(order_svc, order_repo, "")
Rel(order_svc, users_client, "Push tokens")
Rel(order_svc, metrics_client, "Evento")
Rel(order_svc, push_client, "Notifica")
Rel(cart_repo, db, "SQL")
Rel(order_repo, db, "SQL")
Rel(payment_gw, stripe, "HTTPS")
Rel(items_client, itemsApi, "HTTP")
Rel(users_client, usersApi, "HTTP")
Rel(metrics_client, metricsApi, "HTTP")
Rel(push_client, expo, "HTTPS")
Rel(obs_client, obs, "PUT /metrics")

@enduml
